NODE_ENV=development
PORT=5301

# Postgres (local dev via docker-compose: postgres://hee:hee@localhost:5432/hee)
DATABASE_URL=postgres://hee:hee@localhost:5432/hee

# Admin bootstrap token — used only for initial project creation.
# Generate via `openssl rand -hex 32`. Set in prod via secrets manager.
ADMIN_BOOTSTRAP_TOKEN=change-me-to-a-long-random-value
