# Production Caddyfile for edge-1 (Hetzner fsn1, 49.13.214.28).
#
# This Caddy instance is the front door for both:
#   (a) The Hee platform itself — hee.la, app.hee.la, api.hee.la, edge.hee.la
#   (b) Customer-owned custom domains routed here via CNAME → edge.hee.la
#
# DNS:
#   hee.la        → 49.13.214.28 (A)
#   app.hee.la    → 49.13.214.28 (A)   — Portal (placeholder until Phase 2)
#   api.hee.la    → 49.13.214.28 (A)   — Control plane (NestJS on :5301)
#   edge.hee.la   → 49.13.214.28 (A)   — What customers CNAME to
#   *.colbin.com / *.loopai.com / etc. → CNAME edge.hee.la
#
# Customer domains use on-demand TLS; Hee platform hostnames use normal ACME
# (explicit site blocks, so they issue at startup / on first request).

{
  email ops@hee.la

  on_demand_tls {
    # 2xx → issue cert, 4xx/5xx → deny. Control plane runs on localhost:5301;
    # using loopback avoids a circular dependency through Caddy's own :443.
    ask http://localhost:5301/_check-hostname
  }

  # Admin API bound to a Unix socket — mounted into the control-plane
  # container via docker-compose so the reconciler can reach it without
  # TCP exposure, iptables rules, or Origin-header allow-lists. File
  # permissions alone gate access.
  admin unix//run/caddy/admin.sock

  log {
    output stdout
    format json
    level INFO
  }
}

# ── Hee platform hostnames ───────────────────────────────────────────────────

hee.la, www.hee.la {
  # Marketing site — static Astro build, rsync'd from marketing/dist via deploy.sh.
  encode zstd gzip
  root * /opt/hee/marketing/dist
  # Serve /foo/index.html for /foo directly (no 308 round-trip), fall through to =404.
  try_files {path} {path}/index.html =404
  file_server
  # Long cache on hashed assets; short cache on HTML so updates surface quickly.
  @assets path /_astro/* /favicon.svg /robots.txt
  header @assets Cache-Control "public, max-age=31536000, immutable"
  @html path_regexp ^/($|.+/$|.+\.html$)
  header @html Cache-Control "public, max-age=60, must-revalidate"
  handle_errors {
    @404 expression `{err.status_code} == 404`
    handle @404 {
      rewrite * /404.html
      file_server
    }
  }
}

app.hee.la {
  # Portal — Next.js container on 127.0.0.1:3000, behind docker-compose.
  reverse_proxy localhost:3000 {
    transport http {
      dial_timeout 2s
    }
  }
  handle_errors {
    respond "portal not deployed yet" 503
  }
}

api.hee.la {
  # Control plane. Once the NestJS service is running on :5301, traffic flows.
  # Until then, 503 so callers know it's not live yet.
  reverse_proxy localhost:5301 {
    # Fast fail so the placeholder below takes over if the service is down.
    transport http {
      dial_timeout 2s
      response_header_timeout 5s
    }
  }
  handle_errors {
    respond "control plane not deployed yet" 503
  }
}

edge.hee.la {
  # The hostname customers CNAME to. Any direct hit (bots, health checks)
  # gets a simple OK. The real work happens when their custom hostname lands
  # on the on-demand :443 block below.
  respond "hee edge alive" 200
}

docs.hee.la {
  # Docs site — Astro + Starlight static build, rsync'd from docs-site/dist.
  encode zstd gzip
  root * /opt/hee/docs-site/dist
  try_files {path} {path}/index.html =404
  file_server
  @assets path /_astro/* /pagefind/* /favicon.svg
  header @assets Cache-Control "public, max-age=31536000, immutable"
  @html path_regexp ^/($|.+/$|.+\.html$)
  header @html Cache-Control "public, max-age=60, must-revalidate"
  handle_errors {
    @404 expression `{err.status_code} == 404`
    handle @404 {
      rewrite * /404.html
      file_server
    }
  }
}

# ── Customer custom domains (on-demand TLS) ──────────────────────────────────
# No Caddyfile site block for customer traffic. The `:443` server named
# `customers` is created + maintained entirely via the Caddy Admin API by
# the control plane's CaddyReconcilerService. Every domain register/remove
# (and every project upstream-URL change) PATCHes the full server config.
#
# What runs there at runtime (see control-plane/src/modules/caddy/caddy-config.builder.ts):
#   - One route per registered hostname → reverse_proxy to the owning
#     project's upstreamUrl, preserving the client Host header by default
#     so the SaaS upstream can route per-tenant.
#   - A catch-all fallback that rewrites unmatched hosts to /_error-page
#     on the control plane (serves a branded "domain not claimed" page).
#
# The global on_demand_tls ask hook at the top of this file still applies,
# so cert issuance gating remains unchanged.

# ── Catch-all HTTP ───────────────────────────────────────────────────────────
# Redirect everything to HTTPS; expose /_healthz on :80 for LB probes and
# ACME HTTP-01 challenges are auto-handled by Caddy.

:80 {
  @healthz path /_healthz
  handle @healthz {
    respond "ok" 200
  }
  handle {
    redir https://{host}{uri} permanent
  }
}
