---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Hee" description="Page not found.">
  <main class="mx-auto max-w-2xl px-6 py-24 text-center">
    <p class="font-mono text-sm uppercase tracking-widest text-ink-500">404</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight">Page not found</h1>
    <p class="mt-4 text-ink-700">
      The URL looks right but nothing lives here. Head back to the homepage or poke around the features page.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <a href="/" class="btn-primary">Back home</a>
      <a href="/features" class="btn-ghost">See features</a>
    </div>
  </main>
</BaseLayout>
