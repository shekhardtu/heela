---
import BaseLayout from "../layouts/BaseLayout.astro";

const features = [
  {
    title: "Automatic TLS",
    body: "Let's Encrypt issues certs on the first request. No manual uploads, no renewal chores, no expiration surprises.",
  },
  {
    title: "Multi-tenant API",
    body: "Register a domain for a customer with one POST. Per-project API tokens, role-based portal access, no shared secrets.",
  },
  {
    title: "Usage-based pricing",
    body: "Start free with 3 domains. Scale to hundreds for less than one Cloudflare Enterprise hour. No credit card to try.",
  },
  {
    title: "Open edge",
    body: "Caddy + Postgres on a €5 box you can inspect. No proprietary black box between your customer and your origin.",
  },
];

const steps = [
  {
    n: "1",
    title: "Register",
    body: "POST the hostname to <code class=\"font-mono text-xs\">api.hee.la/v1/edge/domains</code> with your project token. We store it and wait for DNS.",
  },
  {
    n: "2",
    title: "Point DNS",
    body: "Your customer adds <span class=\"font-mono text-xs\">CNAME → edge.hee.la</span> in their DNS. That's their entire job.",
  },
  {
    n: "3",
    title: "Serve",
    body: "First request issues a cert. All requests route to your upstream with the original hostname intact. You see it in <code class=\"font-mono text-xs\">Host:</code>.",
  },
];
---

<BaseLayout title="Hee — Custom domains for SaaS, without the Cloudflare Enterprise tax">
  <main>
    <!-- Hero -->
    <section class="mx-auto max-w-6xl px-6 pt-16 pb-20 md:pt-24 md:pb-28">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-ink-50 px-3 py-1 text-xs font-medium text-ink-700">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-green-500"></span>
          Public beta — first design partners live
        </div>
        <h1 class="mt-6 text-4xl font-semibold tracking-tight text-ink-900 md:text-6xl">
          Custom domains for SaaS.<br />
          <span class="text-ink-500">10 minutes, not 10 days.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-700">
          Your customers point a CNAME. You get automatic TLS, routing to your origin, and a multi-tenant API — without touching Cloudflare Enterprise, writing Caddy config, or paying an Approximated markup.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="https://app.hee.la/login" class="btn-primary px-5 py-3 text-base">Start free</a>
          <a href="/compare" class="btn-ghost px-5 py-3 text-base">Why not Cloudflare for SaaS?</a>
        </div>
        <p class="mt-4 text-xs text-ink-500">3 domains free forever · No card · Free TLS</p>
      </div>

      <!-- Terminal / CNAME example -->
      <div class="mx-auto mt-16 max-w-2xl">
        <div class="overflow-hidden rounded-xl border border-ink-200 bg-ink-950 shadow-xl shadow-ink-900/10">
          <div class="flex items-center gap-1.5 border-b border-ink-700 px-4 py-3">
            <span class="h-3 w-3 rounded-full bg-red-400/60"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-400/60"></span>
            <span class="h-3 w-3 rounded-full bg-green-400/60"></span>
            <span class="ml-3 font-mono text-xs text-ink-300">Your customer's DNS</span>
          </div>
          <pre class="overflow-x-auto p-5 font-mono text-sm leading-relaxed text-ink-100"><code><span class="text-ink-500"># One record. No TXT dance. No CAA edits.</span>
docs.customer.com  <span class="text-accent-500">CNAME</span>  <span class="text-green-300">edge.hee.la</span></code></pre>
        </div>
        <p class="mt-3 text-center text-xs text-ink-500">First HTTPS request issues a Let's Encrypt cert in ~3 seconds. Then it's just their domain → your app.</p>
      </div>
    </section>

    <!-- Features grid -->
    <section class="bg-ink-50/50 py-20">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-center text-3xl font-semibold tracking-tight">
          Everything you need, nothing you don't
        </h2>
        <p class="mx-auto mt-3 max-w-2xl text-center text-ink-500">
          Hee is the shared edge: TLS, routing, and a clean API. Your app stays where it is.
        </p>
        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {features.map((f) => (
            <div class="card transition hover:border-ink-300 hover:shadow-sm">
              <h3 class="text-lg font-semibold">{f.title}</h3>
              <p class="mt-2 text-sm text-ink-700">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="mx-auto max-w-6xl px-6 py-20">
      <h2 class="text-center text-3xl font-semibold tracking-tight">How it works</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-ink-500">
        Three steps, ten minutes, zero surprises.
      </p>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {steps.map((s) => (
          <div class="relative rounded-xl border border-ink-200 bg-white p-6">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-ink-900 font-mono text-sm font-semibold text-white">
              {s.n}
            </div>
            <h3 class="mt-4 text-lg font-semibold">{s.title}</h3>
            <p class="mt-2 text-sm text-ink-700" set:html={s.body}></p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="mx-auto max-w-6xl px-6 pb-24">
      <div class="rounded-2xl bg-ink-900 px-8 py-14 text-center text-white md:px-16">
        <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">Stop shipping fallback origins</h2>
        <p class="mx-auto mt-4 max-w-xl text-ink-300">
          If you've hit a Cloudflare for SaaS limitation — Worker routes not firing, custom SNI paywalled, fallback origin bypassing your logic — Hee exists to fix exactly that.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="https://app.hee.la/login" class="inline-flex items-center justify-center rounded-lg bg-white px-5 py-3 text-base font-medium text-ink-900 transition hover:bg-ink-100">Start free</a>
          <a href="https://docs.hee.la" class="inline-flex items-center gap-2 px-4 py-3 text-sm font-medium text-ink-100 hover:text-white">
            Read the docs →
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
