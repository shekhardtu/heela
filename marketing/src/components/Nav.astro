---
const { pathname } = Astro.url;
const isActive = (p: string) => pathname === p || pathname.startsWith(p + "/");
---

<header class="sticky top-0 z-50 border-b border-ink-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2 font-mono text-base font-semibold tracking-tight">
      <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-ink-900 text-xs font-bold text-white">h</span>
      hee
    </a>

    <nav class="hidden items-center gap-1 text-sm md:flex">
      <a
        href="/features"
        class:list={["rounded-md px-3 py-2 text-ink-700 transition hover:bg-ink-50", isActive("/features") && "text-ink-900"]}
      >
        Features
      </a>
      <a
        href="/pricing"
        class:list={["rounded-md px-3 py-2 text-ink-700 transition hover:bg-ink-50", isActive("/pricing") && "text-ink-900"]}
      >
        Pricing
      </a>
      <a
        href="/compare"
        class:list={["rounded-md px-3 py-2 text-ink-700 transition hover:bg-ink-50", isActive("/compare") && "text-ink-900"]}
      >
        Compare
      </a>
      <a
        href="https://docs.hee.la"
        class="rounded-md px-3 py-2 text-ink-700 transition hover:bg-ink-50"
      >
        Docs
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <a href="https://app.hee.la/login" class="btn-ghost text-sm">Sign in</a>
      <a href="https://app.hee.la/login" class="btn-primary text-sm">Get started</a>
    </div>
  </div>
</header>
